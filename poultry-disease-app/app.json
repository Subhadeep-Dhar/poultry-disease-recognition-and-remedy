{
  "expo": {
    "name": "poultry-disease-app",
    "slug": "poultry-disease-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "poultrydiseaseapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Poultry Health to access your photos for disease detection.",
          "cameraPermission": "Allow Poultry Health to use the camera to photograph sick birds."
        }
      ],
      "react-native-fast-tflite"
    ],
    "assetBundlePatterns": [
      "assets/models/*",
      "assets/audio/*",
      "assets/images/*"
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.subhadeepdhar.poultrydiseaseapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
